{
  "name": "@sepoa-jsk/poa-editor",
  "version": "1.0.0",
  "description": "X-Free Editor 5 기능을 현대 브라우저에서 재현한 Vanilla Web Components 기반 리치 텍스트 에디터",
  "type": "module",
  "main": "./dist/poa-editor.cjs.js",
  "module": "./dist/poa-editor.es.js",
  "exports": {
    ".": {
      "import": "./dist/poa-editor.es.js",
      "require": "./dist/poa-editor.cjs.js"
    },
    "./style": "./dist/poa-editor.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:demo": "vite build --config vite.demo.config.js",
    "build:ghpages": "vite build --config vite.ghpages.config.js",
    "build:watch": "vite build --watch",
    "preview": "vite preview",
    "preview:demo": "vite preview --config vite.demo.config.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "keywords": [
    "editor",
    "rich-text",
    "web-components",
    "wysiwyg",
    "javascript"
  ],
  "author": "JSK <claude@sepoasoft.co.kr>",
  "license": "MIT",
  "dependencies": {
    "@codemirror/lang-html": "^6.4.11",
    "axe-core": "^4.11.4",
    "codemirror": "^6.0.2",
    "dompurify": "^3.1.5",
    "idb": "^8.0.0",
    "lucide-static": "^1.14.0"
  },
  "devDependencies": {
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^25.0.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "dompurify": "^3.0.0",
    "idb": "^8.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
